<Window x:Class="PDFSculpt.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PDFSculpt.App.Services"
        xmlns:local="clr-namespace:PDFSculpt.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: PDF Viewer -->
        <ScrollViewer Grid.Column="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

            <Grid>
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding ZoomScale}"
                            ScaleY="{Binding ZoomScale}" />
                </Grid.LayoutTransform>
                <ItemsControl ItemsSource="{Binding Pages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD"
                                    BorderThickness="1"
                                    Margin="10"
                                    Padding="10"
                                    HorizontalAlignment="Center">

                                <Grid>

                                    <Grid>
                                        <!-- PDF Image -->
                                        <Image x:Name="PdfImage"
                                           Source="{Binding ImageData, Converter={StaticResource ByteArrayToImageConverter}}"
                                           Stretch="Uniform"
                                           MaxWidth="900"/>

                                        <!-- Overlay Canvas -->
                                        <Canvas Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Tag="{Binding}"
                                            Loaded="Canvas_Loaded"
                                            MouseDown="Canvas_MouseDown"
                                            MouseMove="Canvas_MouseMove"
                                            MouseUp="Canvas_MouseUp"/>
                                        
                                    </Grid>
                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>


        </ScrollViewer>

        <!-- RIGHT: TOOLBAR -->
        <Border Grid.Column="1"
            Background="#F5F5F5"
            BorderBrush="#DDD"
            BorderThickness="1,0,0,0"
            Padding="10">

            <StackPanel>

                <TextBlock Text="PDFSculpt"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                <Button Content="Open PDF"
                    Command="{Binding OpenPdfCommand}"
                    Margin="0,0,0,10"/>

                <TextBlock Text="{Binding Title}"
                       FontSize="12"
                       Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

                <!-- Zoom -->
                <TextBlock Text="Zoom" FontWeight="SemiBold"/>

                <Slider Minimum="0.5"
                    Maximum="2.0"
                    Value="{Binding Zoom, Mode=TwoWay}"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    Margin="0,5"/>

                <TextBlock Text="{Binding Zoom, StringFormat={}{0:F1}x}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Tools"
                     FontWeight="SemiBold"
                     Margin="0,20,0,10"/>

                <Button Content="Draw"
                    Command="{Binding SelectDrawToolCommand}"
                    Margin="0,0,0,10"/>


            </StackPanel>

        </Border>
    </Grid>
</Window>
